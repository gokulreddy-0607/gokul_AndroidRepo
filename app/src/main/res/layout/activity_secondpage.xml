<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/skyble">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="70dp"
        android:text="Choose a Accommodation"
        android:textSize="35sp"
        android:textStyle="italic"
        android:textColor="#021F10"
        android:padding="20dp"
        android:gravity="center"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/titleText">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Button style card -->
            <!-- 1. Community Sathrams -->
            <Button
                android:id="@+id/btn1"
                android:forceDarkAllowed="false"
                android:text="🏘 Community Sathrams"
                style="@style/MenuButton"/>

            <!-- 2. Hotels -->
            <Button
                android:id="@+id/btn2"
                android:forceDarkAllowed="false"
                android:text="🏩 Hotel rooms"
                style="@style/MenuButton"/>

            <!-- 3. Home Stays -->
            <Button
                android:id="@+id/btn3"
                android:forceDarkAllowed="false"
                android:text="🏠 Home Stays"
                style="@style/MenuButton"/>

            <!-- 4. Luggage Lockers -->
            <Button
                android:id="@+id/btn4"
                android:forceDarkAllowed="false"
                android:text="🧳 Luggage Lockers"
                style="@style/MenuButton"/>

            <Button
                android:id="@+id/btn5"
                android:forceDarkAllowed="false"
                android:text="⏳ Hourly Stay"
                style="@style/MenuButton"/>

            <Button
                android:id="@+id/btn6"
                android:forceDarkAllowed="false"
                android:text="-----"
                style="@style/MenuButton"/>

            <Button
                android:id="@+id/btn7"
                android:forceDarkAllowed="false"
                android:text="------"
                style="@style/MenuButton"/>


            <Button
                android:id="@+id/btn8"
                android:forceDarkAllowed="false"
                android:text="------"
                style="@style/MenuButton"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
