<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/glass_gradient_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:text="Hotel Rooms"
            android:textColor="@color/glass_text_color"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_panel_bg"
            android:orientation="vertical"
            android:padding="24dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/imageRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <Button
                android:id="@+id/btnPhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:background="@drawable/glass_button_bg"
                android:text="Add Photos"
                android:textColor="@color/glass_text_color" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/glass_panel_stroke"
                android:hint="Residence / Hotel Name"
                android:textColor="@color/glass_text_color"
                android:textColorHint="@color/glass_panel_stroke" />

            <EditText
                android:id="@+id/etName1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_panel_stroke"
                android:hint="Year of Establishment"
                android:textColor="@color/glass_text_color"
                android:textColorHint="@color/glass_panel_stroke" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etName3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/glass_panel_stroke"
                    android:hint="Start Cost"
                    android:textColor="@color/glass_text_color"
                    android:textColorHint="@color/glass_panel_stroke" />

                <EditText
                    android:id="@+id/etName4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/glass_panel_stroke"
                    android:hint="Ending Cost"
                    android:textColor="@color/glass_text_color"
                    android:textColorHint="@color/glass_panel_stroke" />
            </LinearLayout>

            <EditText
                android:id="@+id/etBedrooms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_panel_stroke"
                android:hint="Number of Bedrooms"
                android:textColor="@color/glass_text_color"
                android:textColorHint="@color/glass_panel_stroke"
                android:visibility="gone"/>

            <EditText
                android:id="@+id/etBathrooms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_panel_stroke"
                android:hint="Number of Bathrooms"
                android:textColor="@color/glass_text_color"
                android:textColorHint="@color/glass_panel_stroke"
                android:visibility="gone"/>

            <EditText
                android:id="@+id/etLatitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_panel_stroke"
                android:enabled="false"
                android:hint="Latitude"
                android:textColor="@color/glass_text_color"
                android:textColorHint="@color/glass_panel_stroke" />

            <EditText
                android:id="@+id/etLongitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_panel_stroke"
                android:enabled="false"
                android:hint="Longitude"
                android:textColor="@color/glass_text_color"
                android:textColorHint="@color/glass_panel_stroke" />

            <Button
                android:id="@+id/btnGetLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/glass_button_bg"
                android:text="Get GPS"
                android:textColor="@color/glass_text_color" />

            <EditText
                android:id="@+id/tvBusDistance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_panel_stroke"
                android:hint="Bus distance"
                android:textColor="@color/glass_text_color"
                android:textColorHint="@color/glass_panel_stroke" />

            <Button
                android:id="@+id/btnBus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/glass_button_bg"
                android:text="Calculate Bus Stand Distance"
                android:textColor="@color/glass_text_color" />

            <EditText
                android:id="@+id/tvRailDistance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_panel_stroke"
                android:hint="Railway distance"
                android:textColor="@color/glass_text_color"
                android:textColorHint="@color/glass_panel_stroke" />

            <Button
                android:id="@+id/btnRail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/glass_button_bg"
                android:text="Calculate Railway Station Distance"
                android:textColor="@color/glass_text_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="Facilities"
                android:textColor="@color/glass_text_color"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/cbAC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/glass_text_color"
                android:text="AC Rooms"
                android:textColor="@color/glass_text_color" />

            <CheckBox
                android:id="@+id/cbNonAC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/glass_text_color"
                android:text="Non-AC Rooms"
                android:textColor="@color/glass_text_color" />

            <CheckBox
                android:id="@+id/cbHotWater"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/glass_text_color"
                android:text="Hot Water"
                android:textColor="@color/glass_text_color" />

            <CheckBox
                android:id="@+id/cbParking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/glass_text_color"
                android:text="Car Parking"
                android:textColor="@color/glass_text_color" />

            <CheckBox
                android:id="@+id/cbKitchen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/glass_text_color"
                android:text="Kitchen"
                android:textColor="@color/glass_text_color"
                android:visibility="gone"/>

            <RadioGroup
                android:id="@+id/rgStayType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rb24Hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/glass_text_color"
                    android:text="24 Hours Stay"
                    android:textColor="@color/glass_text_color" />

                <RadioButton
                    android:id="@+id/rbCheckInOut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/glass_text_color"
                    android:text="Check-in / Check-out Time"
                    android:textColor="@color/glass_text_color" />
            </RadioGroup>

            <TextView
                android:id="@+id/tv24HoursInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Charge will be 24 hours from check-in time"
                android:textColor="@color/glass_text_color"
                android:textStyle="italic"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutCheckInOut"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etCheckIn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/glass_panel_stroke"
                    android:focusable="false"
                    android:hint="Check-in Time"
                    android:textColor="@color/glass_text_color"
                    android:textColorHint="@color/glass_panel_stroke" />

                <EditText
                    android:id="@+id/etCheckOut"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/glass_panel_stroke"
                    android:focusable="false"
                    android:hint="Check-out Time"
                    android:textColor="@color/glass_text_color"
                    android:textColorHint="@color/glass_panel_stroke" />
            </LinearLayout>

            <EditText
                android:id="@+id/etWebsite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/glass_panel_stroke"
                android:hint="Website URL"
                android:inputType="textUri"
                android:textColor="@color/glass_text_color"
                android:textColorHint="@color/glass_panel_stroke" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_panel_stroke"
                android:hint="Phone Number"
                android:inputType="phone"
                android:textColor="@color/glass_text_color"
                android:textColorHint="@color/glass_panel_stroke" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Star Rating"
                android:textColor="@color/glass_text_color"
                android:textStyle="bold" />

            <RatingBar
                android:id="@+id/ratingBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:numStars="5"
                android:rating="0"
                android:stepSize="0.5"
                android:theme="@style/ThemeOverlay.AppCompat.Dark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Description / Notes"
                android:textColor="@color/glass_text_color"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/glass_panel_stroke"
                android:gravity="top|start"
                android:hint="Enter additional information, rules, or notes"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:maxLines="6"
                android:textColor="@color/glass_text_color"
                android:textColorHint="@color/glass_panel_stroke" />

            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/glass_button_bg"
                android:text="Submit Residence"
                android:textColor="@color/glass_text_color"
                android:textSize="18sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>